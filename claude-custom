# Check if jq is installed
check_jq_dependency() {
    if ! command -v jq &> /dev/null; then
        echo -e "${RED}Error: jq is required but not installed.${NC}"
        echo "Please install jq: brew install jq (macOS) or apt-get install jq (Linux)"
        exit 1
    fi
}

# Check if gum is installed (for TUI features)
check_gum_dependency() {
    if ! command -v gum &> /dev/null; then
        return 1
    fi
    return 0
}

# Show gum installation instructions
show_gum_install() {
    echo -e "${YELLOW}For enhanced TUI experience, install gum:${NC}"
    echo "  brew install gum"
    echo ""
}

# Detect and load existing settings.json
load_settings() {
    local config_file="$1"

    if [[ -f "$config_file" ]]; then
        if jq empty "$config_file" 2>/dev/null; then
            echo -e "${GREEN}Loaded existing configuration from $config_file${NC}"
            return 0
        else
            echo -e "${YELLOW}Warning: Existing config file is not valid JSON${NC}"
            return 1
        fi
    fi

    return 2
}

# Save settings to JSON file
save_settings() {
    local config_file="$1"
    local auth_token="$2"
    local base_url="$3"
    local sonnet_model="$4"
    local opus_model="$5"
    local haiku_model="$6"

    local dir
    dir=$(dirname "$config_file")
    if [[ ! -d "$dir" ]]; then
        mkdir -p "$dir" || {
            echo -e "${RED}Error: Cannot create directory $dir${NC}"
            exit 1
        }
    fi

    local json

    if [[ -f "$config_file" ]]; then
        # File exists - merge with existing values while updating only env
        if jq empty "$config_file" 2>/dev/null; then
            # Use fromjson to parse the existing file content
            json=$(jq -n \
                --arg token "$auth_token" \
                --arg base "$base_url" \
                --arg sonnet "$sonnet_model" \
                --arg opus "$opus_model" \
                --arg haiku "$haiku_model" \
                --arg existing "$(cat "$config_file")" \
                '($existing | fromjson) | .env = {
                    "ANTHROPIC_AUTH_TOKEN": $token,
                    "ANTHROPIC_BASE_URL": $base,
                    "ANTHROPIC_API_KEY": "",
                    "ANTHROPIC_DEFAULT_SONNET_MODEL": $sonnet,
                    "ANTHROPIC_DEFAULT_OPUS_MODEL": $opus,
                    "ANTHROPIC_DEFAULT_HAIKU_MODEL": $haiku
                }')
        else
            # Invalid JSON, create new
            json=$(jq -n \
                --arg token "$auth_token" \
                --arg base "$base_url" \
                --arg sonnet "$sonnet_model" \
                --arg opus "$opus_model" \
                --arg haiku "$haiku_model" \
                '{
                    "env": {
                        "ANTHROPIC_AUTH_TOKEN": $token,
                        "ANTHROPIC_BASE_URL": $base,
                        "ANTHROPIC_API_KEY": "",
                        "ANTHROPIC_DEFAULT_SONNET_MODEL": $sonnet,
                        "ANTHROPIC_DEFAULT_OPUS_MODEL": $opus,
                        "ANTHROPIC_DEFAULT_HAIKU_MODEL": $haiku
                    }
                }')
        fi
    else
        # File doesn't exist - create new
        json=$(jq -n \
            --arg token "$auth_token" \
            --arg base "$base_url" \
            --arg sonnet "$sonnet_model" \
            --arg opus "$opus_model" \
            --arg haiku "$haiku_model" \
            '{
                "env": {
                    "ANTHROPIC_AUTH_TOKEN": $token,
                    "ANTHROPIC_BASE_URL": $base,
                    "ANTHROPIC_API_KEY": "",
                    "ANTHROPIC_DEFAULT_SONNET_MODEL": $sonnet,
                    "ANTHROPIC_DEFAULT_OPUS_MODEL": $opus,
                    "ANTHROPIC_DEFAULT_HAIKU_MODEL": $haiku
                }
            }')
    fi

    # Validate JSON before writing
    if echo "$json" | jq empty 2>/dev/null; then
        (echo "$json" > "$config_file") &
        show_spinner "Saving configuration..." $!
        echo -e "${GREEN}Configuration saved to $config_file${NC}"
    else
        echo -e "${RED}Error: Generated invalid JSON${NC}"
        exit 1
    fi
}

# Backup existing settings.json
backup_settings() {
    local config_file="$1"

    if [[ -f "$config_file" ]]; then
        local timestamp
        timestamp=$(date +%Y%m%d_%H%M%S)
        BACKUP_FILE="${config_file}.backup.${timestamp}"

        (cp "$config_file" "$BACKUP_FILE") &
        show_spinner "Creating backup..." $!
        echo -e "${YELLOW}Backed up existing config to $BACKUP_FILE${NC}"
    fi
}

# ============================================================================
# Scope Selection
# ============================================================================

get_global_config_path() {
    echo "$HOME/.claude/settings.json"
}

get_project_config_path() {
    echo "$(pwd)/.claude/settings.json"
}

validate_writable() {
    local config_file="$1"
    local dir
    dir=$(dirname "$config_file")

    if [[ ! -d "$dir" ]]; then
        if ! mkdir -p "$dir"; then
            echo -e "${RED}Error: Cannot create directory $dir${NC}"
            return 1
        fi
        echo "Created directory: $dir"
    fi

    if [[ -f "$config_file" ]] && [[ ! -w "$config_file" ]]; then
        echo -e "${RED}Error: File $config_file is not writable${NC}"
        return 1
    fi

    if [[ ! -f "$config_file" ]]; then
        # Check if directory is writable by testing directory permissions
        if [[ ! -w "$dir" ]]; then
            echo -e "${RED}Error: Directory $dir is not writable${NC}"
            return 1
        fi
    fi

    return 0
}

prompt_scope_selection() {
    if [[ "$GUM_AVAILABLE" == true ]]; then
        # Use gum for TUI selection
        local choice
        choice=$(gum choose --item.foreground 6 --selected.foreground 2 "Global configuration (~/.claude/settings.json)" "Project configuration (.claude/settings.json in current directory)")

        case "$choice" in
            "Global configuration"*)
                CONFIG_SCOPE="global"
                FILE_CONFIG=$(get_global_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Global configuration"
                return 0
                ;;
            "Project configuration"*)
                CONFIG_SCOPE="project"
                FILE_CONFIG=$(get_project_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Project configuration"
                return 0
                ;;
        esac
    fi

    # Fallback to enhanced numeric input
    while true; do
        echo ""
        echo -e "${ARROW} ${MAGENTA}Select configuration scope:${NC}"
        echo ""
        echo -e "  ${BULLET} ${CYAN}1)${NC} Global   - ~/.claude/settings.json"
        echo -e "  ${BULLET} ${CYAN}2)${NC} Project  - .claude/settings.json (in current directory)"
        echo ""

        local choice
        echo -n "Enter your choice (1 or 2): "
        read_input choice

        case "$choice" in
            1)
                CONFIG_SCOPE="global"
                FILE_CONFIG=$(get_global_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Global configuration"
                return 0
                ;;
            2)
                CONFIG_SCOPE="project"
                FILE_CONFIG=$(get_project_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Project configuration"
                return 0
                ;;
            *)
                print_error "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
}

