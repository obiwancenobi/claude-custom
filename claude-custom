main() {
    case "${1:-}" in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            show_version
            exit 0
            ;;
        -s|--status)
            handle_statusline
            exit $?
            ;;
        -S|--status-disable)
            handle_statusline_disable
            exit 0
            ;;
        -r|--reset)
            handle_reset
            exit 0
            ;;
        -t|--theme)
            handle_theme
            exit 0
            ;;
    esac

    print_ascii_logo "$BLUE"
    echo ""

    check_jq_dependency

    # Check for gum availability and show installation hint if not present
    if [[ "$USE_GUM" == true ]] && check_gum_dependency; then
        GUM_AVAILABLE=true
    else
        if [[ "$USE_GUM" == true ]]; then
            show_gum_install
        fi
        GUM_AVAILABLE=false
    fi

    prompt_scope_selection

    # Validate the config file is writable before proceeding
    if ! validate_writable "$FILE_CONFIG"; then
        echo -e "${RED}Error: Cannot proceed without writable configuration path${NC}"
        exit 1
    fi

    prompt_provider_selection

    prompt_create_config "$FILE_CONFIG"

    read_existing_values "$FILE_CONFIG"

    display_current_config "$FILE_CONFIG" "true"

    prompt_auth_token
    prompt_base_url
    prompt_all_models

    # Show final configuration preview and confirm before saving
    echo ""
    print_header "" "       ${BLUE}Final Configuration Preview${NC}"
    echo ""

    echo -e "  ${MAGENTA}Provider:${NC} ${GREEN}$MODEL_PROVIDER${NC}"
    echo -e "  ${MAGENTA}ANTHROPIC_BASE_URL:${NC} ${GREEN}$BASE_URL${NC}"

    # Mask the auth token for display
    local masked_token
    if [[ -n "$AUTH_TOKEN" ]]; then
        masked_token="[masked]"
    else
        masked_token="[not set]"
    fi
    echo -e "  ${MAGENTA}ANTHROPIC_AUTH_TOKEN:${NC} ${GREEN}$masked_token${NC}"

    echo ""
    echo -e "  ${MAGENTA}ANTHROPIC_DEFAULT_SONNET_MODEL:${NC} ${GREEN}$SONNET_MODEL${NC}"
    echo -e "  ${MAGENTA}ANTHROPIC_DEFAULT_OPUS_MODEL:${NC} ${GREEN}$OPUS_MODEL${NC}"
    echo -e "  ${MAGENTA}ANTHROPIC_DEFAULT_HAIKU_MODEL:${NC} ${GREEN}$HAIKU_MODEL${NC}"
    echo ""

    if [[ "$GUM_AVAILABLE" == true ]]; then
        gum confirm "Does this look correct?" && local confirm_save=true || local confirm_save=false
        if [[ "$confirm_save" == false ]]; then
            echo -e "${YELLOW}Configuration cancelled. No changes made.${NC}"
            exit 0
        fi
    else
        echo -n "Does this look correct? (y/n): "
        local confirm
        read_input confirm
        case "$confirm" in
            y|Y)
                ;;
            *)
                echo -e "${YELLOW}Configuration cancelled. No changes made.${NC}"
                exit 0
                ;;
        esac
    fi

    print_header "" "       ${GREEN}Saving Configuration"

    # Backup existing config before saving
    backup_settings "$FILE_CONFIG"

    # Save the configuration
    save_settings "$FILE_CONFIG" "$AUTH_TOKEN" "$BASE_URL" "$SONNET_MODEL" "$OPUS_MODEL" "$HAIKU_MODEL"

    echo ""
    print_separator
    print_success "${GREEN}Configuration saved successfully!"
    print_separator
    echo -e "${YELLOW}Please restart Claude Code for changes to take effect.${NC}"
    echo ""
}

main "$@"
