# Handle statusline enable (--status/-s)
handle_statusline() {
    print_ascii_logo "$BLUE"
    print_header "" "       ${GREEN}Enable Statusline"
    
    check_jq_dependency
    
    # Check for gum availability - use same logic as main()
    if [[ "$USE_GUM" == true ]] && check_gum_dependency; then
        GUM_AVAILABLE=true
    else
        if [[ "$USE_GUM" == true ]]; then
            show_gum_install
        fi
        GUM_AVAILABLE=false
    fi
        
    # Step 1: Select scope using reusable function
    prompt_scope_selection

    # Validate the config file is writable before proceeding
    if ! validate_writable "$FILE_CONFIG"; then
        echo -e "${RED}Error: Cannot proceed without writable configuration path${NC}"
        exit 1
    fi
    
    # Step 2: Confirm - use same pattern as main() lines 1523-1541 but with fallback
    echo ""
    echo -e "${CYAN}This will enable the Claude statusline in your prompt.${NC}"
    echo -e "${MAGENTA}The statusline shows: ${GREEN}Model ID, Tokens, Git branch, Context bar, Compaction, Cost${NC}"
    echo ""
    
    if [[ "$GUM_AVAILABLE" == true ]]; then
        gum confirm "Enable statusline?" && local confirm_save=true || local confirm_save=false
        if [[ "$confirm_save" == false ]]; then
            echo -e "${YELLOW}Configuration cancelled. No changes made.${NC}"
            exit 0
        fi
    else
        echo -n "Enable statusline? (y/n): "
        local confirm
        read_input confirm
        case "$confirm" in
            y|Y)
                ;;
            *)
                echo -e "${YELLOW}Configuration cancelled. No changes made.${NC}"
                exit 0
                ;;
        esac
    fi
    
    # Save config — statusline.sh is executed directly by Claude Code, not sourced

    # Create directory if needed
    local dir
    dir=$(dirname "$FILE_CONFIG")
    [[ ! -d "$dir" ]] && mkdir -p "$dir"
    
    # Copy statusline script to appropriate location based on scope
    # Resolve symlinks to find the real script location (needed for Homebrew
    # which symlinks from /opt/homebrew/bin/ into the Cellar)
    local real_source="${BASH_SOURCE[0]}"
    while [[ -L "$real_source" ]]; do
        local link_target
        link_target="$(readlink "$real_source")"
        if [[ "$link_target" == /* ]]; then
            real_source="$link_target"
        else
            real_source="$(cd "$(dirname "$real_source")" && pwd)/$link_target"
        fi
    done
    local script_dir
    script_dir="$(cd "$(dirname "$real_source")" && pwd)"
    local statusline_script="$script_dir/functions/statusline.sh"
    local command_path=""

    if [[ ! -f "$statusline_script" ]]; then
        print_error "Could not find functions/statusline.sh at: $statusline_script"
        echo ""
        print_warning "If installed via Homebrew, try: brew upgrade claude-custom"
        echo "  If installed via git clone, ensure the functions/ directory exists."
        echo ""
        return 1
    fi

    if [[ "$CONFIG_SCOPE" == "global" ]]; then
        mkdir -p "$HOME/.claude"
        cp "$statusline_script" "$HOME/.claude/statusline.sh"
        chmod +x "$HOME/.claude/statusline.sh"
        command_path="~/.claude/statusline.sh"
        echo -e "${GREEN}✓${MAGENTA} Copied statusline script to ${GREEN}~/.claude/statusline.sh"
    else
        mkdir -p ".claude"
        cp "$statusline_script" ".claude/statusline.sh"
        chmod +x ".claude/statusline.sh"
        command_path=".claude/statusline.sh"
        echo -e "${GREEN}✓${MAGENTA} Copied statusline script to ${GREEN}.claude/statusline.sh"
    fi

    # Save statusline config, preserving existing settings
    if [[ -f "$FILE_CONFIG" ]] && jq empty "$FILE_CONFIG" 2>/dev/null; then
        jq --arg cmd "$command_path" \
            '.statusLine = {"type": "command", "command": $cmd, "padding": 2}
             | .env.STATUSLINE_THEME //= "detailed"' \
            "$FILE_CONFIG" > "${FILE_CONFIG}.tmp" && mv "${FILE_CONFIG}.tmp" "$FILE_CONFIG"
    else
        jq -n --arg cmd "$command_path" \
            '{"statusLine": {"type": "command", "command": $cmd, "padding": 2}, "env": {"STATUSLINE_THEME": "detailed"}}' \
            > "$FILE_CONFIG"
    fi
    
    echo ""
    print_separator
    print_success "${GREEN}Statusline enabled successfully!"
    print_separator
    echo ""
    echo -e "${YELLOW}Restart Claude Code to see your new statusline!${NC}"
    echo ""
}

# Handle statusline disable (--status-disable/-S)
handle_statusline_disable() {
    print_ascii_logo "$BLUE"
    print_header "" "       ${YELLOW}Disable Statusline"

    check_jq_dependency

    # Check for gum availability and show installation hint if not present
    if [[ "$USE_GUM" == true ]] && check_gum_dependency; then
        GUM_AVAILABLE=true
    else
        if [[ "$USE_GUM" == true ]]; then
            show_gum_install
        fi
        GUM_AVAILABLE=false
    fi

    # Prompt for scope selection
    prompt_scope_selection

    if ! check_config_exists "$FILE_CONFIG"; then
        echo ""
        print_warning "No configuration found at:"
        echo "  $FILE_CONFIG"
        echo ""
        print_info "Nothing to disable."
        exit 0
    fi

    # Check if statusLine key exists
    local has_statusline
    has_statusline=$(jq -e '.statusLine' "$FILE_CONFIG" 2>/dev/null)
    if [[ -z "$has_statusline" ]]; then
        echo ""
        print_info "Statusline is not currently enabled."
        exit 0
    fi

    # Confirm
    echo ""
    echo -e "${CYAN}This will remove the statusline configuration.${NC}"
    echo ""

    if [[ "$GUM_AVAILABLE" == true ]]; then
        gum confirm "Disable statusline?" && local confirm=true || local confirm=false
        if [[ "$confirm" == false ]]; then
            echo -e "${YELLOW}Cancelled. No changes made.${NC}"
            exit 0
        fi
    else
        echo -n "Disable statusline? (y/n): "
        local answer
        read_input answer
        case "$answer" in
            y|Y) ;;
            *)
                echo -e "${YELLOW}Cancelled. No changes made.${NC}"
                exit 0
                ;;
        esac
    fi

    # Backup before modifying
    backup_settings "$FILE_CONFIG"

    # Remove statusLine key from config
    jq 'del(.statusLine)' "$FILE_CONFIG" > "${FILE_CONFIG}.tmp" && mv "${FILE_CONFIG}.tmp" "$FILE_CONFIG"

    # Remove the copied statusline script
    if [[ "$CONFIG_SCOPE" == "global" ]]; then
        rm -f "$HOME/.claude/statusline.sh"
    else
        rm -f ".claude/statusline.sh"
    fi

    echo ""
    print_separator
    print_success "${GREEN}Statusline disabled successfully!"
    print_separator
    echo ""
    echo -e "${YELLOW}Restart Claude Code for changes to take effect.${NC}"
    echo ""
}

# ============================================================================
# Theme Configuration
# ============================================================================

handle_theme() {
    print_ascii_logo "$BLUE"
    print_header "" "       ${CYAN}Statusline Theme"

    check_jq_dependency

    # Check for gum availability
    if [[ "$USE_GUM" == true ]] && check_gum_dependency; then
        GUM_AVAILABLE=true
    else
        if [[ "$USE_GUM" == true ]]; then
            show_gum_install
        fi
        GUM_AVAILABLE=false
    fi

    # Prompt for scope selection
    prompt_scope_selection

    # Show current theme if set
    local current_theme="detailed"
    if [[ -f "$FILE_CONFIG" ]]; then
        local saved
        saved=$(jq -r '.env.STATUSLINE_THEME // ""' "$FILE_CONFIG" 2>/dev/null)
        [[ -n "$saved" ]] && current_theme="$saved"
    fi

    echo ""
    echo -e "${DIM}Current theme: ${CYAN}${current_theme}${NC}"
    echo ""
    echo -e "${BLUE}Available themes:${NC}"
    echo ""
    echo -e "  ${CYAN}1.${NC} ${GREEN}detailed${NC}      - Full info: model, tokens, git, duration, turns, cost"
    echo -e "  ${CYAN}2.${NC} ${BLUE}compact${NC}       - Minimal: model, branch, context % only"
    echo -e "  ${CYAN}3.${NC} ${DIM}monochrome${NC}    - No colors, plain text"
    echo ""

    local choice
    if [[ "$GUM_AVAILABLE" == true ]]; then
        choice=$(gum choose \
            --item.foreground 6 \
            --selected.foreground 2 \
            "detailed" \
            "compact" \
            "monochrome")
    else
        echo -n "Select theme (1/2/3): "
        read_input choice
        case "$choice" in
            1) choice="detailed" ;;
            2) choice="compact" ;;
            3) choice="monochrome" ;;
            "") choice="" ;;
        esac
    fi

    if [[ -z "$choice" ]]; then
        echo -e "${YELLOW}No selection. Aborted.${NC}"
        exit 0
    fi

    # Save to settings.json
    local dir
    dir=$(dirname "$FILE_CONFIG")
    [[ ! -d "$dir" ]] && mkdir -p "$dir"

    if [[ -f "$FILE_CONFIG" ]] && jq empty "$FILE_CONFIG" 2>/dev/null; then
        jq --arg theme "$choice" \
            '.env.STATUSLINE_THEME = $theme' \
            "$FILE_CONFIG" > "${FILE_CONFIG}.tmp" && mv "${FILE_CONFIG}.tmp" "$FILE_CONFIG"
    else
        jq -n --arg theme "$choice" \
            '{"env": {"STATUSLINE_THEME": $theme}}' \
            > "$FILE_CONFIG"
    fi

    echo ""
    print_separator
    print_success "Statusline theme set to: ${GREEN}${choice}${NC}"
    print_separator
    echo ""
    echo -e "${YELLOW}Restart Claude Code to see the new theme!${NC}"
    echo ""
}

