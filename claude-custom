# List of claude-custom keys to reset
CLAUDE_CUSTOM_KEYS=(
    "ANTHROPIC_AUTH_TOKEN"
    "ANTHROPIC_API_KEY"
    "ANTHROPIC_BASE_URL"
    "ANTHROPIC_DEFAULT_SONNET_MODEL"
