AUTH_TOKEN=""
BASE_URL=""
SONNET_MODEL=""
OPUS_MODEL=""
HAIKU_MODEL=""

read_existing_values() {
    local config_file="$1"

    if [[ -f "$config_file" ]] && jq empty "$config_file" 2>/dev/null; then
        AUTH_TOKEN=$(jq -r '.env.ANTHROPIC_AUTH_TOKEN // ""' "$config_file")
        BASE_URL=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$config_file")
        SONNET_MODEL=$(jq -r '.env.ANTHROPIC_DEFAULT_SONNET_MODEL // ""' "$config_file")
        OPUS_MODEL=$(jq -r '.env.ANTHROPIC_DEFAULT_OPUS_MODEL // ""' "$config_file")
        HAIKU_MODEL=$(jq -r '.env.ANTHROPIC_DEFAULT_HAIKU_MODEL // ""' "$config_file")
    fi
}

prompt_auth_token() {
    local retry_count=0
    local max_retries=3

    while [[ $retry_count -lt $max_retries ]]; do
        echo ""
        echo -e "${MAGENTA}ANTHROPIC_AUTH_TOKEN:${NC}"

        if [[ -n "$AUTH_TOKEN" ]]; then
            echo -e "  Current: ${YELLOW}[masked]${NC}"

            if [[ "$GUM_AVAILABLE" == true ]]; then
                # Use gum for password input
                local new_token
                new_token=$(gum input --password --placeholder "Enter new API token (leave empty to keep current)")
                if [[ -n "$new_token" ]]; then
                    AUTH_TOKEN="$new_token"
                fi
            else
                # Fallback to stty
                echo -n "  New value (press Enter to keep current): "
                if stty -echo 2>/dev/null; then
                    local new_token
                    read new_token
                    local read_status=$?
                    stty echo 2>/dev/null

                    if [[ $read_status -eq 0 ]] && [[ -n "$new_token" ]]; then
                        AUTH_TOKEN="$new_token"
                    fi
                else
                    echo -e "${YELLOW}Warning: Could not disable echo. Input will be visible.${NC}"
                    read new_token
                    if [[ -n "$new_token" ]]; then
                        AUTH_TOKEN="$new_token"
                    fi
                fi
            fi
        else
            if [[ "$GUM_AVAILABLE" == true ]]; then
                # Use gum for password input
                AUTH_TOKEN=$(gum input --password --placeholder "Enter API token")
            else
                echo -n "Enter API token: "
                if stty -echo 2>/dev/null; then
                    read AUTH_TOKEN
                    local read_status=$?
                    stty echo 2>/dev/null
                else
                    echo -e "${YELLOW}Warning: Could not disable echo. Input will be visible.${NC}"
                    read AUTH_TOKEN
                fi
            fi
        fi
        echo ""

        if [[ -n "$AUTH_TOKEN" ]]; then
            echo -e "  ${YELLOW}[masked] ${BLUE}will be set as Anthropic Auth Token.${NC}"
            return 0
        fi

        retry_count=$((retry_count + 1))
        echo -e "${RED}Error: Auth token cannot be empty (attempt $retry_count/$max_retries)${NC}"
    done

    echo -e "${RED}Error: Too many failed attempts. Exiting.${NC}"
    exit 1
}

prompt_base_url() {
    # For OpenRouter, it's static - no need to ask
    if [[ "$MODEL_PROVIDER" == "openrouter" ]]; then
        BASE_URL=$(get_provider_base_url "$MODEL_PROVIDER")
        echo ""
        echo -e "${ARROW} ${MAGENTA}ANTHROPIC_BASE_URL:${NC} ${GREEN}$BASE_URL${NC} ${DIM}(static for OpenRouter)${NC}"
        return 0
    fi

    # For Ollama, allow editing since users can have different IP/port
    if [[ "$MODEL_PROVIDER" == "ollama" ]]; then
        local default_base_url
        default_base_url=$(get_provider_base_url "$MODEL_PROVIDER")
        local new_url=""

        # Loop for validation
        while true; do
            echo ""
            echo -e "${ARROW} ${MAGENTA}ANTHROPIC_BASE_URL:${NC}"
            echo -e "  ${DIM}Default:${NC} ${YELLOW}$default_base_url${NC}"

            if [[ -n "$BASE_URL" ]]; then
                echo -e "  ${DIM}Current:${NC} ${YELLOW}$BASE_URL${NC}"
            fi

            if [[ "$GUM_AVAILABLE" == true ]]; then
                local placeholder_text="Enter new value (leave empty to keep default: $default_base_url)"
                new_url=$(gum input --placeholder "$placeholder_text" --prompt.foreground "205" --cursor.foreground "205" --placeholder.background "235")
                if [[ -n "$new_url" ]]; then
                    BASE_URL="$new_url"
                else
                    BASE_URL="$default_base_url"
                fi
            else
                echo -n "  New value (press Enter to keep default): "
                read new_url
                if [[ -n "$new_url" ]]; then
                    BASE_URL="$new_url"
                else
                    BASE_URL="$default_base_url"
                fi
            fi

            # Validate URL format
            if [[ -n "$BASE_URL" ]] && [[ ! "$BASE_URL" =~ ^https?:// ]]; then
                print_error "Base URL must start with http:// or https://"
                BASE_URL=""
                continue
            fi

            if [[ -n "$BASE_URL" ]]; then
                print_success "${GREEN}$BASE_URL ${BLUE}will be set as the base URL."
                return 0
            fi

            print_error "Base URL cannot be empty"
        done
    fi

    # For custom provider, always ask - use loop for validation
    while true; do
        echo ""
        echo -e "${ARROW} ${MAGENTA}ANTHROPIC_BASE_URL:${NC}"
        if [[ -n "$BASE_URL" ]]; then
            echo -e "  ${DIM}Current:${NC} ${YELLOW}$BASE_URL${NC}"

            if [[ "$GUM_AVAILABLE" == true ]]; then
                local placeholder_text="Enter base URL (leave empty to keep current: $BASE_URL)"
                local new_url
                new_url=$(gum input --placeholder "$placeholder_text" --prompt.foreground "205" --cursor.foreground "205" --placeholder.background "235")
                if [[ -n "$new_url" ]]; then
                    BASE_URL="$new_url"
                fi
            else
                echo -n "  New value (press Enter to keep current): "
                read new_url
                if [[ -n "$new_url" ]]; then
                    BASE_URL="$new_url"
                fi
            fi
        else
            if [[ "$GUM_AVAILABLE" == true ]]; then
                BASE_URL=$(gum input --placeholder "Enter base URL (https://...)" --prompt.foreground "205" --cursor.foreground "205" --placeholder.background "235")
            else
                echo -n "Enter base URL: "
                read BASE_URL
            fi
        fi

        # Validate URL format
        if [[ -n "$BASE_URL" ]] && [[ ! "$BASE_URL" =~ ^https?:// ]]; then
            print_error "Base URL must start with http:// or https://"
            BASE_URL=""
        fi

        if [[ -n "$BASE_URL" ]]; then
            print_success "${GREEN}$BASE_URL ${BLUE}will be set as the base URL."
            return 0
        fi

        print_error "Base URL cannot be empty"
    done
}

