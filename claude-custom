# Initialize input buffer from piped input if available
init_input_buffer() {
    # Check if stdin is a pipe (not a terminal)
    if [[ ! -t 0 ]]; then
        # Read all piped input into buffer
        PIPED_INPUT=$(cat /dev/stdin 2>/dev/null)
    fi
}

# Read input - uses buffer if available, otherwise interactive
read_input() {
    local var_name="$1"

    if [[ -n "$PIPED_INPUT" ]]; then
        # Piped input mode - get next line from buffer
        if [[ $INPUT_BUFFER_POS -lt ${#PIPED_INPUT} ]]; then
            # Extract the next line
            local remaining="${PIPED_INPUT:$INPUT_BUFFER_POS}"
            local line
            line=$(echo "$remaining" | head -n1)

            # Trim carriage return if present
            line="${line//$'\r'/}"

            # Update position (add 1 for newline)
            INPUT_BUFFER_POS=$((INPUT_BUFFER_POS + ${#line} + 1))

            # Set the variable using printf for safer assignment
            printf -v "$var_name" '%s' "$line"
        else
            printf -v "$var_name" '%s' ''
        fi
    else
        # Interactive mode - use regular read
        read "$var_name"
    fi
}

# Prompt user to select scope for reset
prompt_reset_scope() {
    if [[ "$GUM_AVAILABLE" == true ]]; then
        # Use gum for TUI selection
        local choice
        choice=$(gum choose --item.foreground 6 --selected.foreground 2 "Global configuration (~/.claude/settings.json)" "Project configuration (.claude/settings.json in current directory)")

        case "$choice" in
            "Global configuration"*)
                CONFIG_SCOPE="global"
                FILE_CONFIG=$(get_global_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Global configuration"
                return 0
                ;;
            "Project configuration"*)
                CONFIG_SCOPE="project"
                FILE_CONFIG=$(get_project_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Project configuration"
                return 0
                ;;
        esac
    fi

    # Fallback to enhanced numeric input
    while true; do
        echo -e "${ARROW} ${MAGENTA}Select configuration scope to reset:${NC}"
        echo ""
        echo -e "  ${BULLET} ${CYAN}1)${NC} Global   - ~/.claude/settings.json"
        echo -e "  ${BULLET} ${CYAN}2)${NC} Project  - .claude/settings.json (in current directory)"
        echo ""

        local choice
        echo -n "Enter your choice (1 or 2): "
        read_input choice

        case "$choice" in
            1)
                CONFIG_SCOPE="global"
                FILE_CONFIG=$(get_global_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Global configuration"
                return 0
                ;;
            2)
                CONFIG_SCOPE="project"
                FILE_CONFIG=$(get_project_config_path)
                print_success "${MAGENTA}Selected: ${GREEN}Project configuration"
                return 0
                ;;
            *)
                print_error "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
}

# Check if configuration file exists at the selected scope
check_config_exists() {
    local config_file="$1"

    if [[ -f "$config_file" ]]; then
        if jq empty "$config_file" 2>/dev/null; then
            return 0
        else
            echo -e "${RED}Error: Configuration file exists but is not valid JSON${NC}"
            return 1
        fi
    else
        # File doesn't exist - this is not an error, just means nothing to reset
        return 2
    fi
}

# Prompt for confirmation before destructive reset
prompt_reset_confirmation() {
    echo ""
    echo -e "${YELLOW}WARNING: This will remove claude-custom configuration from your settings.${NC}"
    echo -e "A backup will be created before any changes.${NC}"
    echo ""

    if [[ "$GUM_AVAILABLE" == true ]]; then
        gum confirm "Are you sure you want to reset?" && return 0 || (echo -e "${YELLOW}Reset cancelled.${NC}" && return 1)
    else
        echo -n "Are you sure you want to reset? (y/n): "
        local confirm
        read_input confirm

        case "$confirm" in
            y|Y)
                return 0
                ;;
            *)
                echo -e "${YELLOW}Reset cancelled.${NC}"
                return 1
                ;;
        esac
    fi
}

# Create backup of claude-custom keys before reset
backup_claude_config() {
    local config_file="$1"
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    BACKUP_FILE="${config_file}.reset.${timestamp}"

    # Extract only claude-custom keys to backup using jq filter
    local keys_json="[]"
    for key in "${CLAUDE_CUSTOM_KEYS[@]}"; do
        local value
        value=$(jq -r ".env.${key} // \"\"" "$config_file" 2>/dev/null)
        if [[ -n "$value" ]]; then
            keys_json=$(echo "$keys_json" | jq --arg k "$key" --arg v "$value" '. + [{"key": $k, "value": $v}]')
        fi
    done

    # Build backup JSON from collected keys
    local backup_json
    backup_json=$(echo "$keys_json" | jq '{"env": [reduce .[] as $item ({}; . + {($item.key): $item.value})]}')

    local env_count
    env_count=$(echo "$keys_json" | jq '. | length' 2>/dev/null)
    if [[ "$env_count" -gt 0 ]]; then
        echo "$backup_json" > "$BACKUP_FILE"
        echo -e "${YELLOW}Backup saved to: $BACKUP_FILE${NC}"
        return 0
    else
        echo -e "${YELLOW}No claude-custom keys found to backup.${NC}"
        BACKUP_FILE=""
        return 1
    fi
}

# Reset claude-custom configuration
reset_config() {
    local config_file="$1"

    # Create backup first
    backup_claude_config "$config_file"

    # Remove claude-custom keys from settings.json
    local temp_file
    temp_file=$(mktemp)

    # Build jq filter to remove all claude-custom keys
    local jq_filter="."
    for key in "${CLAUDE_CUSTOM_KEYS[@]}"; do
        jq_filter="$jq_filter | del(.env.${key})"
    done

    # Show jq errors for debugging if reset fails
    local jq_error
    if ! jq_error=$(jq "$jq_filter" "$config_file" > "$temp_file" 2>&1); then
        rm -f "$temp_file"
        echo -e "${RED}Error: Failed to process configuration file${NC}"
        echo -e "${RED}Details: $jq_error${NC}"
        return 1
    fi

    if [[ -s "$temp_file" ]]; then
        mv "$temp_file" "$config_file"
        return 0
    else
        rm -f "$temp_file"
        echo -e "${RED}Error: Failed to create valid configuration${NC}"
        return 1
    fi
}

# Handle reset operation
handle_reset() {
    print_ascii_logo "$BLUE"
    print_header "" "Reset Configuration"

    check_jq_dependency

    # Check for gum availability and show installation hint if not present
    if [[ "$USE_GUM" == true ]] && check_gum_dependency; then
        GUM_AVAILABLE=true
    else
        if [[ "$USE_GUM" == true ]]; then
            show_gum_install
        fi
        GUM_AVAILABLE=false
    fi

    # Initialize input buffer for piped input support
    init_input_buffer

    # Prompt for scope selection
    prompt_reset_scope

    # Check if config file exists
    if ! check_config_exists "$FILE_CONFIG"; then
        echo ""
        print_warning "No configuration found at:"
        echo "  $FILE_CONFIG"
        echo ""
        print_info "Nothing to reset."
        exit 0
    fi

    # Display current config info
    display_current_config "$FILE_CONFIG" "true"

    # Prompt for confirmation
    if ! prompt_reset_confirmation; then
        exit 0
    fi

    # Perform reset
    if reset_config "$FILE_CONFIG"; then
        echo ""
        print_separator
        print_success "Configuration reset successfully!"
        if [[ -n "$BACKUP_FILE" ]]; then
            print_info "Backup saved to: $BACKUP_FILE"
        fi
        print_separator
        echo ""
        print_warning "Please restart Claude Code for changes to take effect."
    else
        print_error "Failed to reset configuration"
        exit 1
    fi
}

