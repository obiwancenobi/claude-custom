SCRIPT_VERSION="1.4.3"

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2;37m'
NC='\033[0m' # No Color

# UI Icons
SUCCESS="${GREEN}✓${NC}"
FAILURE="${RED}✗${NC}"
INFO="${CYAN}ℹ${NC}"
WARNING="${YELLOW}⚠${NC}"
ARROW="${BLUE}➤${NC}"
BULLET="${CYAN}●${NC}"

# ============================================================================
# UI Helper Functions
# ============================================================================

# Print a visual separator
print_separator() {
    echo -e "${CYAN}────────────────────────────────────────────────────────────────${NC}"
}

# Print a section header with optional step indicator
print_header() {
    local step="$1"
    local title="$2"
    echo ""
    print_separator
    if [[ -n "$step" ]]; then
        echo -e "${CYAN}Step $step:${NC} ${WHITE}$title${NC}"
    else
        echo -e "${WHITE}$title${NC}"
    fi
    print_separator
}

# Print success message
print_success() {
    echo -e "${SUCCESS} $1"
}

# Print error message with hint
print_error() {
    echo -e "${FAILURE} ${RED}Error:${NC} $1"
}

# Print warning message
print_warning() {
    echo -e "${WARNING} ${YELLOW}Warning:${NC} $1"
}

# Print info message
print_info() {
    echo -e "${INFO} $1"
}

# Function to display ASCII logo
print_ascii_logo() {
    local color="${1:-$CYAN}"
    echo -e "${color}"
    echo "    ▄▄█▄▄    ▄▄█▄▄  "
    echo "   ██▀▀██   ██▀▀██ "
    echo "   ██        ██     "
    echo "   ██        ██     "
    echo "   ██▄▄██   ██▄▄██  "
    echo "    ▀▀█▀▀    ▀▀█▀▀  "
    echo ""
    echo -e "  ${color}Claude Custom v${SCRIPT_VERSION}${NC}"
    echo -e "  ${DIM}Claude Code Configuration Manager${NC}"
    echo ""
}

# Loading spinner for background operations
show_spinner() {
    local message="$1"
    local pid=$2
    local delay=0.1
    local spinstr='|/-\'
    printf "${YELLOW}⏳ $message${NC} "
    while kill -0 "$pid" 2>/dev/null; do
        printf "\b${spinstr:0:1}"
        spinstr=${spinstr:1}${spinstr:0:1}
        sleep $delay
    done
    printf "\b${GREEN}✓${NC}\n"
}

# Print confirmation box for final preview
print_confirm_box() {
    local title="$1"
    local width=60

    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
    printf "${CYAN}║${NC}  ${WHITE}%-${width}s${NC}\n" "$title"
    echo -e "${CYAN}╠════════════════════════════════════════════════════════════╣${NC}"
}

