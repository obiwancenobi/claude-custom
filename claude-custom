prompt_create_config() {
    local config_file="$1"

    if [[ -f "$config_file" ]]; then
        return 0
    fi

    echo ""
    echo -e "${YELLOW}No configuration file exists at:${NC}"
    echo "  $config_file"
    echo ""

    if [[ "$GUM_AVAILABLE" == true ]]; then
        gum confirm "Do you want to create a new configuration?" && return 0 || (echo "Aborted. No changes made." && exit 0)
    else
        echo -n "Do you want to create a new configuration? (y/n): "
        read confirm

